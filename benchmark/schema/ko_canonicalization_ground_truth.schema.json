{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ko_canonicalization_ground_truth.schema.json",
  "title": "Knowledge Object Canonicalization Ground Truth",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "version",
    "benchmark_split",
    "status",
    "mention_inventory",
    "annotation_guidelines",
    "evaluation_protocol",
    "schema_bindings",
    "identity_policy",
    "allowed_types",
    "clusters"
  ],
  "properties": {
    "artifact_type": {
      "const": "ko_canonicalization_ground_truth"
    },
    "version": {
      "const": "v0.1"
    },
    "benchmark_split": {
      "enum": [
        "development",
        "holdout"
      ]
    },
    "status": {
      "enum": [
        "draft_annotation_required",
        "frozen"
      ]
    },
    "mention_inventory": {
      "$ref": "#/$defs/artifact_binding"
    },
    "annotation_guidelines": {
      "$ref": "#/$defs/document_binding"
    },
    "evaluation_protocol": {
      "$ref": "#/$defs/document_binding"
    },
    "schema_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mention_inventory",
        "ground_truth"
      ],
      "properties": {
        "mention_inventory": {
          "$ref": "#/$defs/document_binding"
        },
        "ground_truth": {
          "$ref": "#/$defs/document_binding"
        }
      }
    },
    "identity_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cluster_annotation",
        "canonical_id_scheme",
        "cross_type_merge",
        "singleton_records",
        "provenance_retention"
      ],
      "properties": {
        "cluster_annotation": {
          "const": "authoritative"
        },
        "canonical_id_scheme": {
          "const": "opaque_sequential_in_first_mention_order"
        },
        "cross_type_merge": {
          "const": "forbidden"
        },
        "singleton_records": {
          "const": "required"
        },
        "provenance_retention": {
          "const": "through_complete_mention_membership"
        }
      }
    },
    "allowed_types": {
      "const": [
        "Concept",
        "Method",
        "Formula"
      ]
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cluster"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "document_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "version",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_id",
        "canonical_name",
        "canonical_type",
        "mention_ids",
        "aliases",
        "annotation_status",
        "identity_rationale",
        "notes"
      ],
      "properties": {
        "canonical_id": {
          "type": "string",
          "pattern": "^canonical_ko_(dev|holdout)_[0-9]{3}$"
        },
        "canonical_name": {
          "type": "string",
          "minLength": 1
        },
        "canonical_type": {
          "enum": [
            "Concept",
            "Method",
            "Formula"
          ]
        },
        "mention_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ko_mention_(dev|holdout)_[0-9]{3}$"
          }
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "annotation_status": {
          "enum": [
            "draft",
            "pending_review",
            "final"
          ]
        },
        "identity_rationale": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
