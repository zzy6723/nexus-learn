{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidate_pair_generation_rules.schema.json",
  "title": "Candidate Pair Generation Rules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "version",
    "status",
    "method_id",
    "scope",
    "strategy",
    "input_contract",
    "normalization",
    "rules",
    "selection_policy",
    "reason_order",
    "failure_policy"
  ],
  "properties": {
    "artifact_type": {
      "const": "candidate_pair_generation_rules"
    },
    "version": {
      "const": "v0.1"
    },
    "status": {
      "const": "frozen_for_development_baseline"
    },
    "method_id": {
      "const": "rule_filtered_v0_1"
    },
    "scope": {
      "const": "lecture_local_unordered_nonself"
    },
    "strategy": {
      "const": "deterministic_union_filter"
    },
    "input_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_ko_fields",
        "allowed_lecture_fields",
        "forbidden_fields"
      ],
      "properties": {
        "allowed_ko_fields": {
          "const": [
            "lecture_id",
            "predicted_ko_id",
            "name",
            "type",
            "source_spans"
          ]
        },
        "allowed_lecture_fields": {
          "const": [
            "lecture_id",
            "text"
          ]
        },
        "forbidden_fields": {
          "const": [
            "candidate_label",
            "gold_relations",
            "relation_type",
            "gold_evidence",
            "gold_rationale",
            "evaluation_errors",
            "oracle_alignment",
            "pair_id_allowlist"
          ]
        }
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name_matching",
        "lexical",
        "semantic_blocks",
        "symbols"
      ],
      "properties": {
        "name_matching": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "version"
          ],
          "properties": {
            "path": {
              "const": "scripts/knowledge_object_matching.py"
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            },
            "version": {
              "const": "predicted_ko_name_matching_v0_1"
            }
          }
        },
        "lexical": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "token_pattern",
            "stop_tokens"
          ],
          "properties": {
            "token_pattern": {
              "const": "[a-z0-9]+"
            },
            "stop_tokens": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "semantic_blocks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "paragraph_split",
            "display_math_policy",
            "text_normalization"
          ],
          "properties": {
            "paragraph_split": {
              "const": "one_or_more_blank_lines"
            },
            "display_math_policy": {
              "const": "attach_to_immediately_preceding_prose_block"
            },
            "text_normalization": {
              "const": "nfkc_casefold_remove_latex_delimiters_collapse_whitespace"
            }
          }
        },
        "symbols": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "latex_command_pattern",
            "subscript_or_call_identifier_pattern",
            "uppercase_identifier_pattern",
            "stop_symbols"
          ],
          "properties": {
            "latex_command_pattern": {
              "const": "\\\\([A-Za-z]+)"
            },
            "subscript_or_call_identifier_pattern": {
              "const": "\\b([A-Za-z]+)(?=[_(])"
            },
            "uppercase_identifier_pattern": {
              "const": "\\b[A-Z]{2,}\\b"
            },
            "stop_symbols": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_proximity",
        "lexical_overlap",
        "symbol_overlap",
        "explicit_reference",
        "type_compatibility"
      ],
      "properties": {
        "source_proximity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "maximum_semantic_block_distance"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "maximum_semantic_block_distance": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            }
          }
        },
        "lexical_overlap": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "minimum_shared_normalized_tokens"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "minimum_shared_normalized_tokens": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          }
        },
        "symbol_overlap": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "minimum_shared_symbols"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "minimum_shared_symbols": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          }
        },
        "explicit_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "cue_phrases"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "cue_phrases": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 2
              }
            }
          }
        },
        "type_compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "rationale"
          ],
          "properties": {
            "enabled": {
              "const": false
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "selection_policy": {
      "const": "select_if_any_enabled_rule_matches"
    },
    "reason_order": {
      "const": [
        "source_proximity",
        "lexical_overlap",
        "symbol_overlap",
        "explicit_reference",
        "type_compatibility"
      ]
    },
    "failure_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_source_artifact",
        "unknown_endpoint",
        "unlocatable_source_span"
      ],
      "properties": {
        "missing_source_artifact": {
          "const": "fatal"
        },
        "unknown_endpoint": {
          "const": "fatal"
        },
        "unlocatable_source_span": {
          "const": "do_not_trigger_source_proximity"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
