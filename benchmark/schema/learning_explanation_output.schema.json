{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "learning_explanation_output.schema.json",
  "title": "Learning Explanation Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "explanation_instance_id",
    "source_ko_id",
    "relation_type",
    "target_ko_id",
    "connection_summary",
    "why_connected",
    "learning_value",
    "evidence_ids"
  ],
  "properties": {
    "explanation_instance_id": {
      "type": "string",
      "pattern": "^le_(dev|ind)_[0-9]{3}$"
    },
    "source_ko_id": {
      "type": "string",
      "minLength": 1
    },
    "relation_type": {
      "type": "string",
      "enum": [
        "REQUIRES",
        "APPLIED_IN",
        "EXTENDS",
        "CONTRASTS_WITH",
        "FORMALIZES"
      ]
    },
    "target_ko_id": {
      "type": "string",
      "minLength": 1
    },
    "connection_summary": {
      "type": "string",
      "minLength": 1
    },
    "why_connected": {
      "type": "string",
      "minLength": 1
    },
    "learning_value": {
      "type": "string",
      "minLength": 1
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
