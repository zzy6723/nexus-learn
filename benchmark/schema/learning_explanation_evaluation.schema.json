{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "learning_explanation_evaluation.schema.json",
  "title": "Learning Explanation Human Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blind_review_id",
    "explanation_instance_id",
    "claims",
    "faithfulness",
    "failure_labels",
    "learning_value_scores"
  ],
  "properties": {
    "blind_review_id": {
      "type": "string",
      "minLength": 1
    },
    "explanation_instance_id": {
      "type": "string",
      "pattern": "^le_(dev|ind)_[0-9]{3}$"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "field",
          "claim_text",
          "support_label"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "field": {
            "type": "string",
            "enum": [
              "connection_summary",
              "why_connected",
              "learning_value"
            ]
          },
          "claim_text": {
            "type": "string",
            "minLength": 1
          },
          "support_label": {
            "type": "string",
            "enum": [
              "SOURCE_GROUNDED",
              "RELATION_ENTAILED",
              "GENERIC_PEDAGOGICAL_INFERENCE",
              "UNSUPPORTED",
              "CONTRADICTED",
              "UNRESOLVED"
            ]
          }
        }
      }
    },
    "faithfulness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_faithful",
        "direction_faithful",
        "endpoint_faithful",
        "evidence_faithful"
      ],
      "properties": {
        "relation_faithful": {
          "type": "boolean"
        },
        "direction_faithful": {
          "type": "boolean"
        },
        "endpoint_faithful": {
          "type": "boolean"
        },
        "evidence_faithful": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "failure_labels": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "RELATION_DISTORTION",
          "DIRECTION_REVERSAL",
          "EVIDENCE_OVERREACH",
          "ENDPOINT_DRIFT",
          "CONTRADICTION",
          "PEDAGOGICALLY_EMPTY",
          "PEDAGOGICAL_OVERREACH"
        ]
      }
    },
    "learning_value_scores": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "conceptual_mechanism",
            "learning_relevance",
            "specificity",
            "clarity"
          ],
          "properties": {
            "conceptual_mechanism": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2
            },
            "learning_relevance": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2
            },
            "specificity": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2
            },
            "clarity": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2
            }
          }
        }
      ]
    }
  }
}
