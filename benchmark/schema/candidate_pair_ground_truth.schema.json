{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidate_pair_ground_truth.schema.json",
  "title": "Candidate Pair Ground Truth",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "version",
    "benchmark_split",
    "status",
    "pair_universe",
    "source_inventory",
    "annotation_guidelines",
    "relation_annotation_guidelines",
    "evaluation_protocol",
    "success_criteria",
    "allowed_candidate_labels",
    "allowed_relation_types",
    "primary_scoring_labels",
    "annotations"
  ],
  "properties": {
    "artifact_type": {
      "const": "candidate_pair_ground_truth"
    },
    "version": {
      "const": "v0.1"
    },
    "benchmark_split": {
      "enum": [
        "development",
        "holdout"
      ]
    },
    "status": {
      "enum": [
        "draft_annotation_required",
        "frozen"
      ]
    },
    "pair_universe": {
      "$ref": "#/$defs/artifact_binding"
    },
    "source_inventory": {
      "type": "object"
    },
    "annotation_guidelines": {
      "$ref": "#/$defs/document_binding"
    },
    "relation_annotation_guidelines": {
      "$ref": "#/$defs/document_binding"
    },
    "evaluation_protocol": {
      "$ref": "#/$defs/document_binding"
    },
    "success_criteria": {
      "$ref": "#/$defs/document_binding"
    },
    "allowed_candidate_labels": {
      "const": [
        "IN_SCHEMA_RELATION",
        "NO_IN_SCHEMA_RELATION",
        "OUT_OF_SCHEMA_RELATION",
        "AMBIGUOUS"
      ]
    },
    "allowed_relation_types": {
      "const": [
        "REQUIRES",
        "APPLIED_IN",
        "EXTENDS",
        "CONTRASTS_WITH",
        "FORMALIZES",
        "RELATED_TO"
      ]
    },
    "primary_scoring_labels": {
      "const": [
        "IN_SCHEMA_RELATION",
        "NO_IN_SCHEMA_RELATION"
      ]
    },
    "annotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/annotation"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "document_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "version",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "ko_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lecture_id",
        "ko_id"
      ],
      "properties": {
        "lecture_id": {
          "type": "string",
          "minLength": 1
        },
        "ko_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lecture_id",
        "span"
      ],
      "properties": {
        "lecture_id": {
          "type": "string",
          "minLength": 1
        },
        "span": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gold_relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "relation_type",
        "source",
        "target",
        "symmetric",
        "evidence_spans",
        "rationale"
      ],
      "properties": {
        "role": {
          "enum": [
            "primary",
            "acceptable_alternative"
          ]
        },
        "relation_type": {
          "enum": [
            "REQUIRES",
            "APPLIED_IN",
            "EXTENDS",
            "CONTRASTS_WITH",
            "FORMALIZES",
            "RELATED_TO"
          ]
        },
        "source": {
          "$ref": "#/$defs/ko_ref"
        },
        "target": {
          "$ref": "#/$defs/ko_ref"
        },
        "symmetric": {
          "type": "boolean"
        },
        "evidence_spans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_span"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "out_of_schema_relation": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "description",
        "evidence_spans"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence_spans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_span"
          }
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pair_id",
        "candidate_label",
        "annotation_status",
        "gold_relations",
        "out_of_schema_relation",
        "negative_rationale",
        "annotation_source",
        "notes"
      ],
      "properties": {
        "pair_id": {
          "type": "string",
          "pattern": "^cand_(dev|holdout)_[0-9]{3,}$"
        },
        "candidate_label": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "IN_SCHEMA_RELATION",
            "NO_IN_SCHEMA_RELATION",
            "OUT_OF_SCHEMA_RELATION",
            "AMBIGUOUS",
            null
          ]
        },
        "annotation_status": {
          "enum": [
            "draft",
            "final"
          ]
        },
        "gold_relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gold_relation"
          }
        },
        "out_of_schema_relation": {
          "$ref": "#/$defs/out_of_schema_relation"
        },
        "negative_rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "annotation_source": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "new_manual_annotation",
            "reused_existing_relation_annotation",
            "adjudicated",
            null
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
