{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidate_pair_generation_output.schema.json",
  "title": "Candidate Pair Selection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "version",
    "benchmark_split",
    "scope",
    "selection_order",
    "generator",
    "pair_universe",
    "source_inventory",
    "selected_pair_count",
    "selected_pairs"
  ],
  "properties": {
    "artifact_type": {
      "const": "candidate_pair_selection"
    },
    "version": {
      "const": "v0.1"
    },
    "benchmark_split": {
      "enum": [
        "development",
        "holdout"
      ]
    },
    "scope": {
      "const": "lecture_local_unordered_nonself"
    },
    "selection_order": {
      "const": "pair_universe_order"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "implementation",
        "config",
        "config_sha256"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "implementation": {
          "$ref": "#/$defs/artifact_binding"
        },
        "config": {
          "type": "object"
        },
        "config_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "pair_universe": {
      "$ref": "#/$defs/artifact_binding"
    },
    "source_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "normalized_content_sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "normalized_content_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "selected_pair_count": {
      "type": "integer",
      "minimum": 0
    },
    "selected_pairs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selected_pair"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "ko_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lecture_id",
        "ko_id"
      ],
      "properties": {
        "lecture_id": {
          "type": "string",
          "minLength": 1
        },
        "ko_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selected_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pair_id",
        "lecture_id",
        "ko_a",
        "ko_b",
        "candidate_reasons"
      ],
      "properties": {
        "pair_id": {
          "type": "string",
          "pattern": "^cand_(dev|holdout)_[0-9]{3,}$"
        },
        "lecture_id": {
          "type": "string",
          "minLength": 1
        },
        "ko_a": {
          "$ref": "#/$defs/ko_ref"
        },
        "ko_b": {
          "$ref": "#/$defs/ko_ref"
        },
        "candidate_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
