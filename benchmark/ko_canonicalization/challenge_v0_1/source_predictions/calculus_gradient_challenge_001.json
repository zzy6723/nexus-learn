      "name": "Gradient",
      "type": "Concept",
      "source_span": "The gradient of a differentiable scalar function is the vector of its partial derivatives."
    },
    {
      "id": "gradient_coordinate_formula",
      "name": "Gradient Coordinate Formula",
      "type": "Formula",
      "source_span": "\\nabla f(x) = \\left(\\frac{\\partial f}{\\partial x_1},\\ldots,\\frac{\\partial f}{\\partial x_d}\\right)"
    }
  ]
